# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=sikbackup2
DB_PORT=3306

# Orthanc PACS Configuration
ORTHANC_URL=http://localhost:8042
ORTHANC_USERNAME=
ORTHANC_PASSWORD=

# Application Configuration
APP_NAME=Radiology Information System
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/reksorad

# Security Configuration
ENCRYPT_KEY_USER=nur
ENCRYPT_KEY_PASS=windi

# Session Configuration
SESSION_LIFETIME=120
SESSION_PATH=/reksorad

# Mail Configuration (untuk notifikasi - optional)
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_USERNAME=your_username
MAIL_PASSWORD=your_password
MAIL_FROM=noreply@ris.local

# File Upload Configuration
MAX_UPLOAD_SIZE=50M
UPLOAD_PATH=/uploads

# Development Settings
DISPLAY_ERRORS=true
LOG_ERRORS=true
ERROR_LOG=/var/log/ris_errors.log
